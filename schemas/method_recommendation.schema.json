{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Method Recommendation",
  "type": "object",
  "required": [
    "question",
    "recommendations"
  ],
  "properties": {
    "question": {
      "type": "string"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "score",
          "why"
        ],
        "properties": {
          "method": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "why": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}