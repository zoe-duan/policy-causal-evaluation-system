{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_policy.py\"",
            "commandWindows": "py -3 .codex\\hooks\\pre_tool_use_policy.py",
            "timeout": 30,
            "statusMessage": "Checking repository safety policy"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_context.py\"",
            "commandWindows": "py -3 .codex\\hooks\\user_prompt_context.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_review.py\"",
            "commandWindows": "py -3 .codex\\hooks\\post_tool_use_review.py",
            "timeout": 30,
            "statusMessage": "Reviewing command result"
          }
        ]
      }
    ]
  }
}
